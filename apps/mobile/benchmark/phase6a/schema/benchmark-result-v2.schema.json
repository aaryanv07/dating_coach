{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://convocoach.invalid/schemas/phase6a-benchmark-v2.json",
  "title": "ConvoCoach Phase 6A content-free benchmark result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "runtime_platform",
    "runtime_version",
    "native_device_run",
    "cancellation_probe_passed",
    "required_quality_gates_pass",
    "quality_gate_status",
    "session",
    "summary",
    "quality_gates",
    "cases"
  ],
  "properties": {
    "schema_version": { "const": "phase6a-benchmark.v2" },
    "generated_at": { "type": "string", "format": "date-time" },
    "runtime_platform": { "type": "string", "minLength": 1 },
    "runtime_version": { "type": "string", "minLength": 1 },
    "native_device_run": { "type": "boolean" },
    "cancellation_probe_passed": { "type": "boolean" },
    "required_quality_gates_pass": { "type": "boolean" },
    "quality_gate_status": { "enum": ["PASS", "BLOCKED"] },
    "session": { "$ref": "#/$defs/session" },
    "summary": { "$ref": "#/$defs/summary" },
    "quality_gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate" }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "nonNegativeInteger": { "type": "integer", "minimum": 0 },
    "nullableNonNegativeInteger": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "device_model",
        "os_version",
        "flutter_version",
        "ml_kit_version",
        "extraction_version",
        "benchmark_version",
        "started_at",
        "completed_at",
        "elapsed_ms",
        "peak_rss_bytes",
        "peak_rss_delta_bytes",
        "outcome",
        "success",
        "failure_count",
        "cancelled_case_count",
        "cancellation_result"
      ],
      "properties": {
        "platform": { "type": "string", "minLength": 1 },
        "device_model": { "type": "string", "minLength": 1 },
        "os_version": { "type": "string", "minLength": 1 },
        "flutter_version": { "type": "string", "minLength": 1 },
        "ml_kit_version": { "type": "string", "minLength": 1 },
        "extraction_version": { "type": "string", "minLength": 1 },
        "benchmark_version": { "type": "string", "minLength": 1 },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "elapsed_ms": { "$ref": "#/$defs/nonNegativeInteger" },
        "peak_rss_bytes": { "$ref": "#/$defs/nullableNonNegativeInteger" },
        "peak_rss_delta_bytes": { "$ref": "#/$defs/nullableNonNegativeInteger" },
        "outcome": { "enum": ["completed", "failed", "cancelled"] },
        "success": { "type": "boolean" },
        "failure_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "cancelled_case_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "cancellation_result": { "enum": ["passed", "failed"] }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_count",
        "completed_count",
        "failed_count",
        "cancelled_count",
        "character_accuracy",
        "word_accuracy",
        "message_extraction_accuracy",
        "event_classification_accuracy",
        "minimum_fixture_message_extraction_accuracy",
        "speaker_assignment_accuracy",
        "timestamp_accuracy",
        "duplicate_removal_accuracy",
        "ordering_accuracy",
        "warning_accuracy",
        "manual_review_rate",
        "review_recall",
        "review_precision",
        "average_correction_count",
        "p50_latency_ms",
        "p95_latency_ms",
        "maximum_peak_rss_delta_bytes",
        "cleanup_success_rate",
        "confidence_available_for_all"
      ],
      "properties": {
        "fixture_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "completed_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "failed_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "cancelled_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "character_accuracy": { "$ref": "#/$defs/ratio" },
        "word_accuracy": { "$ref": "#/$defs/ratio" },
        "message_extraction_accuracy": { "$ref": "#/$defs/ratio" },
        "event_classification_accuracy": { "$ref": "#/$defs/ratio" },
        "minimum_fixture_message_extraction_accuracy": { "$ref": "#/$defs/ratio" },
        "speaker_assignment_accuracy": { "$ref": "#/$defs/ratio" },
        "timestamp_accuracy": { "$ref": "#/$defs/ratio" },
        "duplicate_removal_accuracy": { "$ref": "#/$defs/ratio" },
        "ordering_accuracy": { "$ref": "#/$defs/ratio" },
        "warning_accuracy": { "$ref": "#/$defs/ratio" },
        "manual_review_rate": { "$ref": "#/$defs/ratio" },
        "review_recall": { "$ref": "#/$defs/ratio" },
        "review_precision": { "$ref": "#/$defs/ratio" },
        "average_correction_count": { "type": "number", "minimum": 0 },
        "p50_latency_ms": { "$ref": "#/$defs/nonNegativeInteger" },
        "p95_latency_ms": { "$ref": "#/$defs/nonNegativeInteger" },
        "maximum_peak_rss_delta_bytes": { "$ref": "#/$defs/nullableNonNegativeInteger" },
        "cleanup_success_rate": { "$ref": "#/$defs/ratio" },
        "confidence_available_for_all": { "type": "boolean" }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "actual", "target", "required", "passed"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "actual": { "type": ["number", "null"] },
        "target": { "type": ["number", "null"] },
        "required": { "type": "boolean" },
        "passed": { "type": ["boolean", "null"] }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "inspiration",
        "traits",
        "image_count",
        "expected_message_count",
        "status",
        "latency_ms",
        "peak_rss_bytes",
        "peak_rss_delta_bytes",
        "cleanup_succeeded",
        "provider",
        "provider_version",
        "confidence_available",
        "metrics",
        "failure_category"
      ],
      "properties": {
        "fixture_id": { "type": "string", "minLength": 1 },
        "inspiration": { "type": "string", "minLength": 1 },
        "traits": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "image_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "expected_message_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "status": { "enum": ["completed", "failed", "cancelled"] },
        "latency_ms": { "$ref": "#/$defs/nonNegativeInteger" },
        "peak_rss_bytes": { "$ref": "#/$defs/nullableNonNegativeInteger" },
        "peak_rss_delta_bytes": { "$ref": "#/$defs/nullableNonNegativeInteger" },
        "cleanup_succeeded": { "type": "boolean" },
        "provider": { "type": "string", "minLength": 1 },
        "provider_version": { "type": "string", "minLength": 1 },
        "confidence_available": { "type": "boolean" },
        "metrics": { "oneOf": [{ "$ref": "#/$defs/metrics" }, { "type": "null" }] },
        "failure_category": { "type": ["string", "null"] }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "character_accuracy",
        "word_accuracy",
        "message_extraction_accuracy",
        "event_classification_accuracy",
        "speaker_assignment_accuracy",
        "timestamp_accuracy",
        "duplicate_removal_accuracy",
        "ordering_accuracy",
        "warning_accuracy",
        "manual_review_rate",
        "review_recall",
        "review_precision",
        "corrections"
      ],
      "properties": {
        "character_accuracy": { "$ref": "#/$defs/ratio" },
        "word_accuracy": { "$ref": "#/$defs/ratio" },
        "message_extraction_accuracy": { "$ref": "#/$defs/ratio" },
        "event_classification_accuracy": { "$ref": "#/$defs/ratio" },
        "speaker_assignment_accuracy": { "$ref": "#/$defs/ratio" },
        "timestamp_accuracy": { "$ref": "#/$defs/ratio" },
        "duplicate_removal_accuracy": { "$ref": "#/$defs/ratio" },
        "ordering_accuracy": { "$ref": "#/$defs/ratio" },
        "warning_accuracy": { "$ref": "#/$defs/ratio" },
        "manual_review_rate": { "$ref": "#/$defs/ratio" },
        "review_recall": { "$ref": "#/$defs/ratio" },
        "review_precision": { "$ref": "#/$defs/ratio" },
        "corrections": {
          "type": "object",
          "additionalProperties": false,
          "required": ["text", "speaker", "timestamp", "missing", "extra", "order", "total"],
          "properties": {
            "text": { "$ref": "#/$defs/nonNegativeInteger" },
            "speaker": { "$ref": "#/$defs/nonNegativeInteger" },
            "timestamp": { "$ref": "#/$defs/nonNegativeInteger" },
            "missing": { "$ref": "#/$defs/nonNegativeInteger" },
            "extra": { "$ref": "#/$defs/nonNegativeInteger" },
            "order": { "$ref": "#/$defs/nonNegativeInteger" },
            "total": { "$ref": "#/$defs/nonNegativeInteger" }
          }
        }
      }
    }
  }
}
