APP_NAME=ConvoCoach API
APP_ENVIRONMENT=local
APP_DEBUG=true

POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=convocoach
POSTGRES_PASSWORD=convocoach_local_only
POSTGRES_DB=convocoach
DATABASE_URL=postgresql+asyncpg://convocoach:convocoach_local_only@127.0.0.1:5432/convocoach

REDIS_HOST_BIND=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# Local-only mock identity. Production environments fail closed without a
# provider-backed AuthenticationVerifier.
DEVELOPMENT_AUTH_TOKEN=convocoach-local-token
DEVELOPMENT_AUTH_SUBJECT=local-user
DEVELOPMENT_AUTH_EMAIL=local@convocoach.invalid
