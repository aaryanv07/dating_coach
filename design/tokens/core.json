{
  "$description": "ConvoCoach platform-neutral core design tokens",
  "spacing": {
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "small": { "$type": "dimension", "$value": "4px" },
    "medium": { "$type": "dimension", "$value": "8px" },
    "full": { "$type": "dimension", "$value": "999px" }
  },
  "size": {
    "minimumTouchTarget": { "$type": "dimension", "$value": "44px" },
    "iconSmall": { "$type": "dimension", "$value": "16px" },
    "iconMedium": { "$type": "dimension", "$value": "24px" }
  },
  "typography": {
    "fontFamily": {
      "sans": {
        "$type": "fontFamily",
        "$value": "system-ui, -apple-system, BlinkMacSystemFont, sans-serif"
      }
    },
    "fontSize": {
      "caption": { "$type": "dimension", "$value": "12px" },
      "body": { "$type": "dimension", "$value": "16px" },
      "title": { "$type": "dimension", "$value": "20px" },
      "headline": { "$type": "dimension", "$value": "28px" }
    },
    "lineHeight": {
      "caption": { "$type": "number", "$value": 1.4 },
      "body": { "$type": "number", "$value": 1.5 },
      "heading": { "$type": "number", "$value": 1.25 }
    }
  }
}
